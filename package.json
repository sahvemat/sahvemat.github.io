{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:11ty\"",
    "dev:css": "npx -y @tailwindcss/cli -i assets/css/input.css -o assets/css/style.css --watch",
    "dev:11ty": "npx -y @11ty/eleventy --serve --port 3000",
    "build": "npx -y @tailwindcss/cli -i assets/css/input.css -o assets/css/style.css && npx -y @11ty/eleventy",
    "clean": "rm -rf dist assets/css/style.css",
    "lint": "echo 'No linting configured for pure HTML/Jekyll setup'"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0-beta.2"
  }
}
